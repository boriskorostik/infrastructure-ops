# Скопируй в ~/.config/clvr-admin/clvr-admin.env или передай параметры install.sh.
CLVR_LOGIN=dispetcher
CLVR_PASSWORD=change-me
CLVR_IP=192.168.48.20
CLVR_PORT=29107
CLVR_SPACE=Space79

# Watchdog: если процесс держит одно ядро около 100% дольше 2 минут, сервис перезапускается.
CLVR_CPU_LIMIT=90
CLVR_CPU_TIME=120

# Обычно менять не нужно.
CLVR_PROC=/opt/A7Admin/CLVR/usr/bin/CLVR-admin
CLVR_WATCHDOG_LOG=/var/log/clvr/clvr-watchdog.log
